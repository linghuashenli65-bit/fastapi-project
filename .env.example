# 服务配置
PROJECT_NAME=沃林学生管理系统
API_PREFIX=/
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 数据库配置（请修改为你的数据库密码）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=student_management_system

# PostgreSQL 示例（二选一）
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=123456
# DB_NAME=fastapi_demo

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_FORMAT=%(asctime)s - %(levelname)s - %(message)s

# JWT 配置（请使用生成的强密钥，生成命令：openssl rand -hex 32）
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 大模型API配置（请填入你的API密钥）
QWEN_API_KEY=your_qwen_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 前端API地址（用于开发环境）
FRONTEND_API_BASE=http://localhost:8000
